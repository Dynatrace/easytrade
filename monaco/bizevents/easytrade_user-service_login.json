{
  "enabled": true,
  "ruleName": "{{ .name }}",
  "triggers": [
    {
      "source": {
        "dataSource": "request.path"
      },
      "type": "EQUALS",
      "value": "/api/auth/login",
      "caseSensitive": false
    },
    {
      "source": {
        "dataSource": "request.method"
      },
      "type": "EQUALS",
      "value": "POST",
      "caseSensitive": false
    }
  ],
  "event": {
    "provider": {
      "sourceType": "constant.string",
      "source": "www.easytrade.com"
    },
    "type": {
      "sourceType": "constant.string",
      "source": "com.easytrade.login"
    },
    "category": {
      "sourceType": "request.path"
    },
    "data": [
      {
        "name": "username",
        "source": {
          "sourceType": "request.body",
          "path": "username"
        }
      },
      {
        "name": "password",
        "source": {
          "sourceType": "request.body",
          "path": "password"
        }
      },
      {
        "name": "accountId",
        "source": {
          "sourceType": "response.body",
          "path": "id"
        }
      }
    ]
  }
}
